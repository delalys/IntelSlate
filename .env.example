# =============================================================================
# IntelSlate Environment Variables
# =============================================================================
# Copy this file to .env and update values with your actual credentials
# IMPORTANT: Never commit .env to version control - it contains secrets!
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL connection string for Prisma
# For local development with docker-compose:
DATABASE_URL="postgresql://intelslate:intelslate_dev_password@localhost:5432/intelslate?schema=public"

# For production, use your actual PostgreSQL credentials:
# DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# -----------------------------------------------------------------------------
# External API Keys (Server-side only - DO NOT prefix with NEXT_PUBLIC_)
# -----------------------------------------------------------------------------

# Logo.dev API - Company logos
# Get your API key at: https://logo.dev/
LOGO_DEV_API_KEY="your_logo_dev_api_key_here"

# Tavily API - AI-powered news search
# Get your API key at: https://tavily.com/
TAVILY_API_KEY="your_tavily_api_key_here"

# -----------------------------------------------------------------------------
# AI/LLM Configuration
# -----------------------------------------------------------------------------

# Ollama base URL for local AI processing
# Default for local Ollama installation:
OLLAMA_BASE_URL="http://localhost:11434"